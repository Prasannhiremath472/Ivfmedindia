# ── Copy this to your Hostinger hPanel → Node.js → Environment Variables ──

NODE_ENV=production
PORT=3000

# MySQL (get these from Hostinger hPanel → Databases)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT (use a long random string — min 32 chars)
JWT_SECRET=change_this_to_a_very_long_random_secret_key_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=another_long_random_secret_for_refresh_tokens
JWT_REFRESH_EXPIRES_IN=30d

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=noreply@ivfmedindia.com
EMAIL_FROM_NAME=IVFMedIndia

# Admin
ADMIN_EMAIL=admin@ivfmedindia.com

# Frontend URL (your actual domain)
FRONTEND_URL=https://www.ivfmedindia.com

# Cloudinary (optional — for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Rate limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# WhatsApp number (digits only, with country code)
VITE_WHATSAPP=918888888888
